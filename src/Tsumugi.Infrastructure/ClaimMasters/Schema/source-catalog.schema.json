{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tsumugi.local/schema/source-catalog.schema.json",
  "title": "Tsumugi claim master source catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sources", "releases"],
  "properties": {
    "schemaVersion": { "const": "1" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/release" }
    }
  },
  "$defs": {
    "relation": {
      "type": ["array", "null"],
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentId",
        "title",
        "publisher",
        "effectiveAt",
        "publishedAt",
        "retrievedAt",
        "url",
        "sha256",
        "supersedes",
        "corrects",
        "supplements",
        "applicabilityNote",
        "correctionNote"
      ],
      "properties": {
        "documentId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "effectiveAt": { "type": "string", "format": "date" },
        "publishedAt": { "type": ["string", "null"], "format": "date" },
        "retrievedAt": { "type": "string", "format": "date" },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "supersedes": {
          "type": ["array", "null"],
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "corrects": { "$ref": "#/$defs/relation" },
        "supplements": { "$ref": "#/$defs/relation" },
        "applicabilityNote": { "type": ["string", "null"], "minLength": 1 },
        "correctionNote": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["masterVersion", "effectiveFrom", "effectiveTo", "sourceDocumentIds"],
      "properties": {
        "masterVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
        "effectiveFrom": { "type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$" },
        "effectiveTo": {
          "type": ["string", "null"],
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
        },
        "sourceDocumentIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
