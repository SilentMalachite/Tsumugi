<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Tsumugi.App.ViewModels"
        xmlns:views="using:Tsumugi.App.Views"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Tsumugi.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Tsumugi — 就労継続支援B型">
    <TabControl x:Name="MainTabs"
                SelectedIndex="{Binding SelectedSection, Mode=TwoWay}">
        <TabItem Header="利用者一覧(_1)">
            <views:RecipientListView DataContext="{Binding RecipientList}" />
        </TabItem>
        <TabItem Header="利用者登録/編集(_2)">
            <views:RecipientEditView DataContext="{Binding RecipientEdit}" />
        </TabItem>
        <TabItem Header="障害者手帳(_3)">
            <views:DisabilityCertificateView DataContext="{Binding DisabilityCertificate}" />
        </TabItem>
        <TabItem Header="フェースシート(_4)">
            <views:FaceSheetView DataContext="{Binding FaceSheet}" />
        </TabItem>
        <TabItem Header="受給者証(_5)">
            <views:CertificateView DataContext="{Binding Certificate}" />
        </TabItem>
        <TabItem Header="契約(_6)">
            <views:ContractView DataContext="{Binding Contract}" />
        </TabItem>
        <TabItem Header="日次記録(_7)">
            <views:DailyRecordView DataContext="{Binding DailyRecord}" />
        </TabItem>
        <TabItem Header="事業所(_8)">
            <views:OfficeView DataContext="{Binding Office}" />
        </TabItem>
        <TabItem Header="事業所体制(_9)">
            <views:OfficeCapabilityView DataContext="{Binding OfficeCapability}" />
        </TabItem>
        <!-- Phase 2 tabs. Alt+1..9 は Phase 1 で消費済みのため、文字キーで割り当てる。 -->
        <TabItem Header="作業実績(_A)">
            <views:WorkRecordView DataContext="{Binding WorkRecord}" />
        </TabItem>
        <TabItem Header="工賃原資・設定(_B)">
            <views:WageFundSettingsView DataContext="{Binding WageFundSettings}" />
        </TabItem>
        <TabItem Header="利用者時給(_E)">
            <views:RecipientHourlyRateView DataContext="{Binding RecipientHourlyRate}" />
        </TabItem>
        <TabItem Header="特別手当(_F)">
            <views:WageAdjustmentView DataContext="{Binding WageAdjustment}" />
        </TabItem>
        <TabItem Header="工賃計算(_C)">
            <views:WageCalculationView DataContext="{Binding WageCalculation}" />
        </TabItem>
        <TabItem Header="工賃確定(_D)">
            <views:WageStatementView DataContext="{Binding WageStatement}" />
        </TabItem>
        <TabItem Header="請求入力(_G)" IsVisible="{Binding ClaimInputAvailable}">
            <views:ClaimInputView DataContext="{Binding ClaimInput}" />
        </TabItem>
    </TabControl>
</Window>
