<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tsumugi.App.ViewModels"
             xmlns:conv="using:Tsumugi.App.Converters"
             x:Class="Tsumugi.App.Views.ContractView"
             x:DataType="vm:ContractViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding DiscardCommand}" />
    </UserControl.KeyBindings>
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="契約管理" FontSize="16" Margin="8,8,8,4" />
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="8">
            <StackPanel Spacing="4">
                <TextBlock Text="利用者（必須）" />
                <ComboBox ItemsSource="{Binding Recipients}"
                          SelectedItem="{Binding SelectedRecipient}"
                          PlaceholderText="利用者を選択"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding KanjiName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="契約開始日（yyyy-MM-dd）" />
                <TextBox Text="{Binding PeriodStart, Converter={x:Static conv:DateOnlyConverter.Instance}}"
                         Watermark="例：2026-04-01" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="契約支給量（日/月）" />
                <TextBox Text="{Binding ContractedSupplyDays, StringFormat={}{0}}"
                         Watermark="例：20" />
            </StackPanel>
            <TextBlock Text="{Binding SaveErrorMessage}"
                       Foreground="#FF4444"
                       IsVisible="{Binding SaveErrorMessage, Converter={x:Static conv:StringNotEmptyConverter.Instance}}" />
            <TextBlock Text="{Binding OverlapWarning}"
                       Foreground="#FFAA00"
                       IsVisible="{Binding OverlapWarning, Converter={x:Static conv:StringNotEmptyConverter.Instance}}" />
            <Button Content="保存 (Ctrl+S)" Command="{Binding SaveCommand}" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Items}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  Margin="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="期間" Binding="{Binding Period}" Width="*" />
                <DataGridTextColumn Header="支給量（日）" Binding="{Binding ContractedSupplyDays}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
