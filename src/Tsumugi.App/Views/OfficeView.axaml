<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tsumugi.App.ViewModels"
             xmlns:enums="using:Tsumugi.Domain.Enums"
             xmlns:conv="using:Tsumugi.App.Converters"
             x:Class="Tsumugi.App.Views.OfficeView"
             x:DataType="vm:OfficeViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding DiscardCommand}" />
    </UserControl.KeyBindings>
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="事業所管理"
                   FontSize="{DynamicResource HeadingFontSize}" Margin="8,8,8,4" />
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="8">
            <StackPanel Spacing="4">
                <TextBlock Text="事業所番号" />
                <TextBox Text="{Binding OfficeNumber}" Watermark="例：2700012345" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="事業所名" />
                <TextBox Text="{Binding Name}" Watermark="例：つむぎ作業所" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="サービス種別" />
                    <!-- ServiceCategory enum 全値をバインド。現状は TypeB のみだが将来拡張用に Items を enum 全列挙にする。 -->
                    <ComboBox SelectedItem="{Binding Category}" MinWidth="160">
                        <ComboBox.Items>
                            <enums:ServiceCategory>TypeB</enums:ServiceCategory>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="地域区分" />
                    <ComboBox SelectedItem="{Binding Region}" MinWidth="160">
                        <ComboBox.Items>
                            <enums:RegionGrade>None</enums:RegionGrade>
                            <enums:RegionGrade>Grade1</enums:RegionGrade>
                            <enums:RegionGrade>Grade2</enums:RegionGrade>
                            <enums:RegionGrade>Grade3</enums:RegionGrade>
                            <enums:RegionGrade>Grade4</enums:RegionGrade>
                            <enums:RegionGrade>Grade5</enums:RegionGrade>
                            <enums:RegionGrade>Grade6</enums:RegionGrade>
                            <enums:RegionGrade>Grade7</enums:RegionGrade>
                            <enums:RegionGrade>Other</enums:RegionGrade>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="{Binding SaveErrorMessage}"
                       Foreground="#FF4444"
                       IsVisible="{Binding SaveErrorMessage, Converter={x:Static conv:StringNotEmptyConverter.Instance}}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="新規登録 (Ctrl+S)" Command="{Binding SaveCommand}" />
                <Button Content="更新（選択中）" Command="{Binding UpdateCommand}" />
            </StackPanel>
        </StackPanel>
        <DataGrid ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  Margin="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="事業所番号" Binding="{Binding OfficeNumber}" Width="Auto" />
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
