<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tsumugi.App.ViewModels"
             xmlns:enums="using:Tsumugi.Domain.Enums"
             xmlns:conv="using:Tsumugi.App.Converters"
             x:Class="Tsumugi.App.Views.WageFundSettingsView"
             x:DataType="vm:WageFundSettingsViewModel">
    <ScrollViewer>
        <StackPanel Margin="8" Spacing="8">
            <TextBlock Text="工賃原資と設定"
                       FontSize="{DynamicResource HeadingFontSize}" />

            <StackPanel Spacing="4">
                <TextBlock Text="事業所（必須）" />
                <ComboBox ItemsSource="{Binding Offices}"
                          SelectedItem="{Binding SelectedOffice}"
                          PlaceholderText="事業所を選択"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <TextBlock Text="月次原資（WageFund）"
                       FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="年" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Year}" Minimum="1900" Maximum="9999" Width="100" FormatString="0" />
                <TextBlock Text="月" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Month}" Minimum="1" Maximum="12" Width="80" FormatString="0" />
                <TextBlock Text="原資（円）" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding TotalYen}" Minimum="0" Maximum="100000000" Width="160" FormatString="0" />
                <TextBlock Text="{Binding FormattedTotalYen}" VerticalAlignment="Center" />
                <Button Content="保存" Command="{Binding SaveFundCommand}" />
            </StackPanel>
            <TextBox Text="{Binding FundNote}" Watermark="メモ（任意）" />

            <TextBlock Text="設定（WageSettings）"
                       FontSize="{DynamicResource BaseFontSize}" FontWeight="Bold" Margin="0,16,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="開始日" VerticalAlignment="Center" />
                <TextBox Text="{Binding PeriodStart, Converter={x:Static conv:DateOnlyConverter.Instance}}"
                         Watermark="2026-04-01" Width="140" />
                <TextBlock Text="方式" VerticalAlignment="Center" />
                <ComboBox SelectedItem="{Binding Method}">
                    <enums:WageMethod>Piece</enums:WageMethod>
                    <enums:WageMethod>Hourly</enums:WageMethod>
                    <enums:WageMethod>Fixed</enums:WageMethod>
                    <enums:WageMethod>Equal</enums:WageMethod>
                </ComboBox>
                <TextBlock Text="固定日額（円）" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding FixedDailyYen}" Minimum="0" Maximum="1000000" Width="120" FormatString="0" />
            </StackPanel>

            <!-- 作業手当日額 -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <TextBlock Text="作業手当日額（円）" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding WorkAllowancePerDayYen}"
                               Minimum="0" Maximum="1000000" Width="120" FormatString="0" />
            </StackPanel>

            <!-- 工賃最小単位 -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <TextBlock Text="工賃最小単位（分）" VerticalAlignment="Center" />
                <ComboBox SelectedItem="{Binding HourUnitMinutes}" MinWidth="80">
                    <x:Int32>1</x:Int32>
                    <x:Int32>2</x:Int32>
                    <x:Int32>3</x:Int32>
                    <x:Int32>4</x:Int32>
                    <x:Int32>5</x:Int32>
                    <x:Int32>6</x:Int32>
                    <x:Int32>10</x:Int32>
                    <x:Int32>12</x:Int32>
                    <x:Int32>15</x:Int32>
                    <x:Int32>20</x:Int32>
                    <x:Int32>30</x:Int32>
                    <x:Int32>60</x:Int32>
                </ComboBox>
            </StackPanel>

            <!-- 職能手当 閾値段 -->
            <TextBlock Text="職能手当（閾値段）" Margin="0,8,0,0" FontWeight="Bold" />
            <ItemsControl ItemsSource="{Binding SkillAllowanceTiers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SkillAllowanceTierViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <NumericUpDown Value="{Binding MinHours}"
                                           Minimum="0" Maximum="9999" Width="100" FormatString="0" />
                            <TextBlock Text="時間以上" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding Yen}"
                                           Minimum="0" Maximum="1000000" Width="120" FormatString="0" />
                            <TextBlock Text="円" VerticalAlignment="Center" />
                            <Button Content="削除" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="＋ 段を追加" Command="{Binding AddSkillAllowanceTierCommand}"
                    Margin="0,4,0,0" />

            <Button Content="保存" Command="{Binding SaveSettingsCommand}" Margin="0,8,0,0" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
