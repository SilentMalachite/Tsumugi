<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tsumugi.App.ViewModels"
             x:Class="Tsumugi.App.Views.WageCalculationView"
             x:DataType="vm:WageCalculationViewModel">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="工賃計算（プレビュー）"
                   FontSize="{DynamicResource HeadingFontSize}" Margin="8,8,8,4" />
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="8,0,8,8">
            <TextBlock Text="事業所（必須）" />
            <ComboBox ItemsSource="{Binding Offices}"
                      SelectedItem="{Binding SelectedOffice}"
                      PlaceholderText="事業所を選択"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,0,8,8">
            <TextBlock Text="年" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Year}" Minimum="1900" Maximum="9999" Width="100" FormatString="0" />
            <TextBlock Text="月" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Month}" Minimum="1" Maximum="12" Width="80" FormatString="0" />
            <Button Content="計算" Command="{Binding LoadPreviewCommand}" IsEnabled="{Binding !IsBusy}" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Width="100" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Text="{Binding SummaryLine}"
                   Margin="8,0,8,4" FontWeight="Bold" />
        <Border DockPanel.Dock="Top" Background="#553300" Padding="8" Margin="8,0"
                IsVisible="{Binding HasMismatchWarning}">
            <TextBlock Text="警告: 配分計と原資が一致していません" Foreground="White" />
        </Border>
        <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorMessage}" Foreground="Red" Margin="8,0" />
        <DataGrid ItemsSource="{Binding Lines}" Margin="8" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="利用者 ID" Binding="{Binding RecipientId}" Width="*" />
                <DataGridTextColumn Header="金額（円）" Binding="{Binding AmountYen}" Width="120" />
                <DataGridTextColumn Header="根拠" Binding="{Binding BasisSummary}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
