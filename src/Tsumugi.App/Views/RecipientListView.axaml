<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tsumugi.App.ViewModels"
             xmlns:conv="using:Tsumugi.App.Converters"
             x:Class="Tsumugi.App.Views.RecipientListView"
             x:DataType="vm:RecipientListViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding LoadCommand}" />
        <KeyBinding Gesture="Enter" Command="{Binding EditCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding DeleteCommand}" />
    </UserControl.KeyBindings>
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4">
            <TextBlock Text="利用者一覧"
                       FontSize="{DynamicResource HeadingFontSize}" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <CheckBox Content="アーカイブ済みも表示"
                          IsChecked="{Binding IncludeArchived}" />
                <Button Content="編集 (Enter)" Command="{Binding EditCommand}" />
                <Button Content="削除 (Del)" Command="{Binding DeleteCommand}" />
                <Button Content="復元" Command="{Binding RestoreCommand}" />
            </StackPanel>
        </DockPanel>
        <TextBlock DockPanel.Dock="Top" Margin="8,0,8,4"
                   Text="{Binding OperationMessage}"
                   Foreground="#FF4444"
                   IsVisible="{Binding OperationMessage, Converter={x:Static conv:StringNotEmptyConverter.Instance}}" />
        <DataGrid ItemsSource="{Binding Items}"
                  SelectedItem="{Binding Selected}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  Margin="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="氏名（漢字）" Binding="{Binding KanjiName}" Width="*" />
                <DataGridTextColumn Header="氏名（カナ）" Binding="{Binding KanaName}" Width="*" />
                <DataGridTextColumn Header="生年月日" Binding="{Binding DateOfBirth}" Width="Auto" />
                <DataGridTextColumn Header="状態"
                                    Binding="{Binding IsArchived, Converter={x:Static vm:ArchivedStatusConverter.Instance}}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
