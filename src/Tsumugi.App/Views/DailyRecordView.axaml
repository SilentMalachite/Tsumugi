<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tsumugi.App.ViewModels"
             xmlns:enums="using:Tsumugi.Domain.Enums"
             x:Class="Tsumugi.App.Views.DailyRecordView"
             x:DataType="vm:DailyRecordViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding LoadCommand}" />
    </UserControl.KeyBindings>
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="日次記録"
                   FontSize="{DynamicResource HeadingFontSize}" Margin="8,8,8,4" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,0,8,8">
            <TextBlock Text="利用者" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding Recipients}"
                      SelectedItem="{Binding SelectedRecipient}"
                      PlaceholderText="選択してください"
                      MinWidth="180">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding KanjiName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="年" VerticalAlignment="Center" Margin="8,0,0,0" />
            <NumericUpDown Value="{Binding Year}" Minimum="1900" Maximum="9999" FormatString="0" Width="100" />
            <TextBlock Text="月" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Month}" Minimum="1" Maximum="12" FormatString="0" Width="80" />
            <Button Content="表示 (F5)" Command="{Binding LoadCommand}" />
        </StackPanel>
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Cells}" Margin="8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:DailyCellViewModel">
                        <!-- セル寸法と文字サイズは UiDefaults.MinimumFontSize に追従する。固定 px は使わない。 -->
                        <Border BorderBrush="#444" BorderThickness="1" Margin="2"
                                MinWidth="{DynamicResource DailyCellSize}"
                                MinHeight="{DynamicResource DailyCellSize}">
                            <StackPanel Spacing="2" Margin="4">
                                <TextBlock Text="{Binding Date.Day}"
                                           FontWeight="Bold"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding EffectiveAttendance}"
                                           FontSize="{DynamicResource BaseFontSize}"
                                           HorizontalAlignment="Center" />
                                <!-- 出欠ボタンは SetAttendanceCommand に統一。既存記録があれば訂正、無ければ新規に分岐する。 -->
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="出" Padding="4,2" Margin="1"
                                            FontSize="{DynamicResource BaseFontSize}"
                                            Command="{Binding SetAttendanceCommand}"
                                            CommandParameter="{x:Static enums:Attendance.Present}" />
                                    <Button Content="欠" Padding="4,2" Margin="1"
                                            FontSize="{DynamicResource BaseFontSize}"
                                            Command="{Binding SetAttendanceCommand}"
                                            CommandParameter="{x:Static enums:Attendance.Absent}" />
                                    <Button Content="対" Padding="4,2" Margin="1"
                                            FontSize="{DynamicResource BaseFontSize}"
                                            Command="{Binding SetAttendanceCommand}"
                                            CommandParameter="{x:Static enums:Attendance.AbsenceSupport}" />
                                    <Button Content="取" Padding="4,2" Margin="1"
                                            FontSize="{DynamicResource BaseFontSize}"
                                            Command="{Binding CancelCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
